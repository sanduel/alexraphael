---
import { Image } from "astro:assets";
import tourGroup from "../assets/tour-group.jpg";
---

<section class="px-6 pt-10 pb-16 md:pt-20 md:pb-24">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 md:gap-16 items-center">
    <div class="order-2 md:order-1">
      <h1 class="text-5xl md:text-7xl leading-[1.05] tracking-tight">
        Alex Raphaël
      </h1>
      <p class="mt-6 text-xl md:text-2xl font-serif italic text-[--color-ink]/75 leading-snug">
        Walking tours of New York's layered history.
      </p>
      <a
        href="#signup"
        class="mt-10 inline-flex items-center gap-2 text-sm uppercase tracking-[0.18em] text-[--color-accent] hover:opacity-70 transition"
      >
        <span>Subscribe for tour announcements</span>
        <span aria-hidden="true">↓</span>
      </a>
    </div>

    <div class="order-1 md:order-2">
      <Image
        src={tourGroup}
        alt="Alex leading a walking tour group near Union Square on a clear winter day"
        widths={[400, 800, 1200, 1800]}
        sizes="(max-width: 768px) 100vw, 50vw"
        class="w-full h-auto rounded-sm shadow-[0_20px_40px_-20px_rgba(0,0,0,0.25)]"
      />
    </div>
  </div>
</section>
